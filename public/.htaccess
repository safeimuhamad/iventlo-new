RewriteEngine On
RewriteBase /iventlo-new/public/

# Redirect browser requests that still expose the physical public directory.
RewriteCond %{THE_REQUEST} \s/+iventlo-new/public(?:[/?\s]) [NC]
RewriteRule ^(.*)$ /iventlo-new/$1 [R=301,L,NE]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+)$ index.php?route=$1 [QSA,L]
